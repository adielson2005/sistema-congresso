# Ambiente
APP_ENV=production

# Flask
SECRET_KEY=troque-por-uma-chave-forte-e-longa
PORT=8080
SESSION_COOKIE_SECURE=true
SESSION_LIFETIME_HOURS=12
MAX_CONTENT_LENGTH=2097152

# Protecao de login
LOGIN_MAX_ATTEMPTS=10
LOGIN_ATTEMPT_WINDOW_SECONDS=900
LOGIN_LOCKOUT_SECONDS=900

# Banco (PostgreSQL)
DATABASE_URL=postgresql://usuario:senha@localhost:5432/sistema_congreso

# Login único compartilhado do sistema
SINGLE_LOGIN_USER=Ujadepa
SINGLE_LOGIN_PASSWORD=cadepa2026@
SINGLE_LOGIN_NAME=Login compartilhado
SINGLE_LOGIN_ROLE=admin

# Login do caixa adolescentes (usa o mesmo usuario/senha do sistema)
CAIXA_LOGIN_NAME=Caixa Adolescentes

# Fallback opcional: usuário inicial no banco
DEFAULT_ADMIN_USER=Ujadepa
DEFAULT_ADMIN_PASSWORD=cadepa2026@
DEFAULT_ADMIN_NAME=Administrador
DEFAULT_ADMIN_ROLE=admin

# Gunicorn (Docker)
WEB_CONCURRENCY=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=60
